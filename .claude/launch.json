{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "php",
      "runtimeArgs": ["artisan", "serve"],
      "cwd": "backend",
      "port": 8000
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "queue",
      "runtimeExecutable": "php",
      "runtimeArgs": ["artisan", "queue:work"],
      "cwd": "backend",
      "port": 8001
    }
  ]
}
