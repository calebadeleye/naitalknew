# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# SMTP Configuration for Contact Form
# For local testing, you can use Mailtrap (https://mailtrap.io)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_password
SMTP_SECURE=false

# Google Maps Platform (Required for Reviews and Maps)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
GOOGLE_PLACE_ID=0x103b9a71c0022179:0x9995260dae04b06e

# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
VITE_LARAVEL_API_URL=http://127.0.0.1:8000

# Port the Express server (server.js) listens on
PORT=3000

# Backend/admin login for /admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
ADMIN_SESSION_SECRET=change-this-long-random-secret
