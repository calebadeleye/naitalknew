VAT_RATE=0.075

COMPANY_NAME="NAI TALK SERVICES"
COMPANY_ADDRESS_LINE_1="7, Unity Rd,"
COMPANY_ADDRESS_LINE_2="Ikola, Lagos."
COMPANY_PHONE="+234 813 517 1217"
